I18N["zh-TW"]["orgs/settings/apps"] = { // 組織設置 - GitHub 應用
    "static": { // 靜態翻譯
        ...I18N["zh-TW"]["orgs-settings-menu"]["static"],

        // GitHub 應用 /organizations/<org-login>/settings/apps
            "No GitHub Apps": "尚無 GitHub 應用",
                "Want to build something that integrates with and extends GitHub? Register a new GitHub App to get started developing on the GitHub API.": "想創建與 GitHub 集成並擴展 GitHub 的應用嗎？註冊一個新的 GitHub 應用，開始使用 GitHub API 進行開發。",
