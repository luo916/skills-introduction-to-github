        [/Successfully removed (@[^\n]+) as a moderator/, "已成功將 $1 的版主身份移除"],
        ...I18N["zh-TW"]["orgs-public"]["regexp"],
    ],
};

I18N["zh-TW"]["orgs/settings/repository-defaults"] = { // 組織設置 - 儲存庫 / 預設值
    "static": { // 靜態翻譯
        ...I18N["zh-TW"]["orgs-settings-menu"]["static"],

        // 儲存庫預設分支 /organizations/<org-login>/settings/repository-defaults
            "Repository default branch": "儲存庫預設分支",
                "Choose the default branch for new repositories in this organization. You might want to change the default name due to different workflows, or because your integrations still require “master” as the default branch name. You can always change the default branch name on individual repositories.": "為該組織中的新儲存庫選擇預設的分支。由於工作流程的不同，或者由於您的集成仍然需要 “master” 作為預設分支名，您可能想改變預設名稱。您可以隨時改變單個儲存庫的預設分支名稱。",
                "Learn more about default branches.": "瞭解更多關於預設分支的訊息。",

            // 頂部提醒
                // [/New repositories created in ([^ ]+) will use main as their default branch./, "在 $1 中創建的新儲存庫將使用 main 作為其預設分支。"],

            "Commit signoff": "提交簽署",
                "Choose whether repositories will require contributors to sign off on commits they make through GitHub's web interface. Signing off is a way for contributors to affirm that their commit complies with the repository's terms, commonly the": "選擇儲存庫是否要求貢獻者簽署通過 GitHub 的 Web 介面所做的提交。簽署是貢獻者確認他們的提交符合儲存庫條款的一種方式，通常是",
                "Developer Certificate of Origin (DCO)": "開發者來源證書（DCO）",
                "Learn more about signing off on commits": "瞭解更多關於簽署提交的訊息",
                "All repositories": "所有儲存庫",
                    "Require signoff on web-based commits for all repositories in this organization": "要求對該組織中所有儲存庫的基於 Web 的提交進行簽署",
                "No policy": "無政策",
                    "Each repository chooses whether to require signoff on web-based commits": "每個儲存庫選擇是否要求對基於 Web 的提交進行簽署",

                // 頂部提醒
                    "Commit signoff settings were updated.": "提交簽署設置已更新。",

            "Repository labels": "儲存庫標籤",
                "Set the labels that will be included when a new repository is created in this organization.": "設置在此組織中創建新的儲存庫時將包含的標籤。",
                "Learn more about managing default labels for your organization.": "瞭解更多關於為您的組織管理預設標籤的訊息。",
            "New label": "新建標籤",
                "Label preview": "標籤預覽",
                "Label name": "標籤名",
                "Description": "描述",
                "Description (optional)": "描述（可選）",
                "Color": "顏色",
                    "Get a new color": "獲得新顏色",
