    "regexp": [ // 正則翻譯
        [/Started (\d+) discussions? in this repository in the past day/, "過去一天內在此儲存庫中開啟了 $1 個討論"], // 用戶 浮動訊息卡
        [/Started (\d+) discussions? in this repository in the past week/, "過去一週內在此儲存庫中開啟了 $1 個討論"], // 用戶 浮動訊息卡
        [/Started (\d+) discussions? in this repository in the past month/, "過去一個月內在此儲存庫中開啟了 $1 個討論"], // 用戶 浮動訊息卡
        [/Started (\d+) discussions? in this repository/, "在此儲存庫中開啟了 $1 個討論"], // 用戶 浮動訊息卡
        [/Opened this pull request \(their first in ([^ ]+)\)/, "打開了這個合併請求（首次在 $1 發表）"], // 用戶 浮動訊息卡
        [/([^ ]+) requested changes, you commented/, "$1 要求更改，您發表評論"], // 合併請求 浮動訊息卡
        [/(\d+) successful checks?/, "$1 個成功的檢查"],
        [/(\d+) successful/, "$1 成功"],
        [/(@\S+) generated this status\./, "$1 創建了這個狀態"],
        [/Successful in (\d+)s/, "在 $1 秒內成功"],
        [/Successful in (\d+)m/, "在 $1 分內成功"],
        [/(\d+) failing checks?/, "$1 個失敗的檢查"],
        // 3 skipped
        [/(\d+) skipped/, "$1 個跳過"],
        [/Failing after (\d+)s/, "在 $1 秒後失敗"],
        [/(\d+) in progress check/, "$1 個正在執行的檢查"],
        // [/ and /, " 和 "],
        [/, and (\d+) more/, "，以及其他 $1 個組織"], // 用戶 浮動訊息卡
        [/^(\d+) repositor(y|ies)/, "$1 個儲存庫"], // 組織  浮動訊息卡
        [/(\d+) members?/, "$1 個成員"], // 組織  浮動訊息卡
        [/Answered (\d+) discussions? in this repository in the past month/, "過去一個月內在此儲存庫中回答了 $1 個討論"], // 用戶 浮動訊息卡
        [/Answered (\d+) discussions? in this repository in the past week/, "過去一週內在此儲存庫中回答了 $1 個討論"], // 用戶 浮動訊息卡
        [/Answered (\d+) discussions? in this repository/, "在此儲存庫中回答了 $1 個討論"], // 用戶 浮動訊息卡
        [/had recent pushes (\d+) seconds? ago/, "分支有了最新的推送，$1 秒之前"],
        [/had recent pushes (\d+) minutes? ago/, "分支有了最新的推送，$1 分鐘之前"],
        [/had recent pushes less than (\d+) minutes? ago/, "分支有了最新的推送，不到 $1 分鐘"],
        [/had recent pushes about/, "分支有了最新的推送，大約"],
        [/This user is a member of the ([^ ]+) organization./, "該用戶是 $1 組織的成員。"],
        [/This user has been invited to collaborate on the ([^ ]+) repository./, "該用戶已被邀請在 $1 儲存庫上進行協作。"],
        [/You are the owner of the (.*) repository./, "您是 $1 儲存庫的所有者。"],
        [/This user is the owner of the (.*) repository./, "該用戶是 $1 儲存庫的所有者。"],
        [/You have been invited to collaborate on the (.*) repository./, "您已受邀參與 $1 儲存庫的協作。"],
        [/You have previously committed to the (.*) repository./, "您之前有提交到 $1 儲存庫。"],
        [/This user has previously committed to the (.*) repository./, "該用戶之前有提交到 $1 儲存庫。"],
        [/This repository was archived by the owner on (.+). It is now read-only./, (match, p1) => {
            const dateRegExp = I18N["zh-TW"]["public"]["time-regexp"];
            const translatedDate = dateRegExp.reduce((acc, [pattern, replacement]) => acc.replace(pattern, replacement), p1);
            return `此儲存庫已由所有者於${translatedDate}存檔。它現在是只讀的。`;
        }],
        [/, and ([^ ]+)/, ", 和 $1"],
        [/reacted with (thumbs up|thumbs down|laugh|hooray|confused|heart|rocket|eyes) emoji/, function (all, reacted) {
            var reactedKey = {'thumbs up': "點贊", 'thumbs down': "點踩", laugh: "大笑", hooray: "歡呼", confused: "表示困惑", heart: "比心", rocket: "發送火箭", eyes: "表示追蹤"};

            return reactedKey[reacted];
        }],
        // 成為協作者提示
        [/You now have push access to the ([^ ]+) repository./, "您現在擁有推送至 $1 儲存庫的權限"],
        ...I18N["zh-TW"]["orgs-public"]["regexp"],
        // 提交 - 作者窗
        [/(\d+) authors?/, "$1 作者"],
    ],
};

