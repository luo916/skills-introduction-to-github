        [/Show ([\d,]+) more matches?/, "顯示更多 $1 處匹配"],
        [/(\d+) issues? needs? help/, "$1 個議題需要幫助"],
        [/Sponsor ([^ ]+)?/, "贊助 $1"], // 贊助按鈕 對話框 標題
