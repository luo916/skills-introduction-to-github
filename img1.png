                "Add a filter": "新增",
                    "Text": "文本",
                "Apply": "應用",

        // 關閉彈窗
            "Discard changes?": "是否放棄更改？",
            "You have unsaved changes. Are you sure you want to discard them?": "您有未保存的更改。您確定要放棄它們嗎？",
            "Keep editing": "繼續編輯",
            "Close and discard": "關閉並放棄",

        // 篩選器報錯視窗
            "Empty value for": "空值：",
            "Text will be ignored since log searching is not yet available:": "由於尚未提供日誌搜尋功能，文本將被忽略：",

        // 工作流相關
            "Workflows": "工作流",
            "Jobs": "作業",
                "Job": "作業",
                "Job runs": "作業執行",
                "Runtime OS": "操作系統",
                "Runner type": "執行器類型",
                    "hosted": "託管",
                    "hosted-larger": "大型託管",
                    "self-hosted": "自託管",
                "Runner labels": "執行器標籤",

        // 無資料
            "No table data available yet.": "還沒有資料。",
                "You don't have workflows on any of your organization repositories.": "您的任何組織儲存庫中都沒有工作流程。",
            "Get started with GitHub Actions": "快速開始",

        // 工作流條目
            "Workflow": "工作流",
            "Workflow runs": "工作流執行",

        "of": "/",
    },
    "regexp": [
        [/Showing data from (\d+)\/(\d+)\/(\d+) to/, "顯示資料：從$1年$2月$3日至"],
        [/Total (minutes|job runs) across all workflows in this (organization|repository) for (current week \(mon-sun\)|current month|last month|last 30 days|last 90 days|last year|custom)/, function(all, type, scope, period){
            var typeKey = {'minutes': '總分鐘數', 'job runs': '作業執行總數'};
            var scopeKey = {'organization': '該組織', 'repository': '該儲存庫'};
            var periodKey = {
                "current week (mon-sun)": "本週（週一 ~ 週日）",
                "current month": "本月",
                "last month": "上個月",
                "last 30 days": "最近 30 天",
                "last 90 days": "最近 90 天",
                "last year": "最近一年",
                "custom": "自定義時間段",
            };
            return periodKey[period] + scopeKey[scope] + '所有工作流的' + typeKey[type];
        }],
        [/Period: (Current week \(Mon-Sun\)|Current month|Last month|Last 30 days|Last 90 days|Last year|Custom)/, function(all, period){
            var periodKey = {
                "Current week (Mon-Sun)": "本週（週一 ~ 週日）",
                "Current month": "本月",
                "Last month": "上個月",
                "Last 30 days": "最近 30 天",
                "Last 90 days": "最近 90 天",
                "Last year": "最近一年",
                "Custom": "自定義",
            };
            return '範圍：' + periodKey[period];
        }],
    ],
};

I18N["zh-TW"]["repository/actions/metrics/usage"] = {
    "static": {
        ...I18N["zh-TW"]["repo-actions-merics-public"]["static"],

        "Total minutes": "總分鐘數",
        "Total job runs": "總作業執行次數",

        "Row Actions": "更多", // 暫譯
        "View performance": "查看資料看板",
    },
    "regexp": [
        ...I18N["zh-TW"]["repo-actions-merics-public"]["regexp"],
    ],
    "title": {
        "static": {
            "Actions usage metrics": "操作使用情況",
        },
    },
};

I18N["zh-TW"]["repository/actions/metrics/performance"] = {
    "static": {
        ...I18N["zh-TW"]["repo-actions-merics-public"]["static"],

        "Avg job run time": "平均作業執行時長",
        "Avg job queue time": "平均作業等待時長",
        "Job failure rate": "作業失敗率",
        "Failed job usage": "作業失敗次數",

        "<1s": "<1秒",

        "Avg run time minutes": "平均執行時長",
        "Avg queue time minutes": "平均等待時長",
        "Failure rate": "失敗率",

        "Has job failures": "作業失敗率",
        "Avg run time": "平均執行時長",
        "Avg queue time": "平均等待時長",

        "Row Actions": "更多", // 暫譯
        "View usage": "查看使用情況",
    },
    "regexp": [
        ...I18N["zh-TW"]["repo-actions-merics-public"]["regexp"],
        [/(Average run time of|Average queue time of|Failure rate across|Total minutes used across failed) jobs in this repository for (current week \(mon-sun\)|current month|last month|last 30 days|last 90 days|last year|custom)/, function(all, type, period){
            var typeKey = {'Average run time of': '平均執行時長', 'Average queue time of': '平均等待時長', 'Failure rate across': '作業失敗率', 'Total minutes used across failed': '作業失敗次數'};
            var periodKey = {
                "current week (mon-sun)": "本週（週一 ~ 週日）",
                "current month": "本月",
                "last month": "上個月",
                "last 30 days": "最近 30 天",
                "last 90 days": "最近 90 天",
                "last year": "最近一年",
                "custom": "自定義時間段",
            };
            return periodKey[period] + '該儲存庫所有工作流程的' + typeKey[type];
        }],
        [/(\d+)h (\d+)m (\d+)s/, "$1時$2分$3秒"],
        [/(\d+)m (\d+)s/, "$1分$2秒"],
        [/(\d+)m/, "$1分鐘"],
    ],
    "title": {
        "static": {
            "Actions performance metrics": "操作資料看板",
        },
    },
};

