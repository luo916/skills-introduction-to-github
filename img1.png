        [/(\d+) Failed invitations?/, "$1 失敗邀請"],
        [/Invite a member to/, "邀請成員加入"],
        [/Convert ([^ ]+) to outside collaborator?/, "將 $1 轉換為外部協作者？"],
        [/Removing (\d+) members? from/, "移除 $1 名成員，從"],
        [/(\d+) pe(?:ople|rson) in the ([^ ]+) organization/, "$2 組織中的 $1 位成員"],
        [/(\d+) security managers? in the ([^ ]+) organization/, "$2 組織中的 $1 位安全管理員"],
        [/You've invited ([^ ]+) to ([^ ]+)! They'll be receiving an email shortly. They can also visit ([^ ]+) to accept the invitation./, "您已邀請 $1 加入到 $2 ！他們很快就會收到一封電子郵件。他們還可以訪問 $3 接受邀請。"],
        [/You've successfully updated ([^ ]+)'s invitation./, "您已成功更新 $1 的邀請。"],
        [/Cancel invitation from ([^ ]+)/, "取消來自 $1 的邀請"],
        [/You've canceled (\d+) invitations? from ([^ ]+). It may take a few minutes to process./, "您已經取消了來自 $2 的 $1 個邀請。可能需要幾分鐘處理。"],
        [/(\d+) invitations?/, "$1 邀請"],
        [/Invited on (.+)/, (match, p1) => {
            const dateRegExp = I18N["zh-TW"]["public"]["time-regexp"];
            const translatedDate = dateRegExp.reduce((acc, [pattern, replacement]) => acc.replace(pattern, replacement), p1);
            return `邀請於${translatedDate}`;
        }],
        ...I18N["zh-TW"]["orgs-public"]["regexp"],
   ],
    "title": {
