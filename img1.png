        [/(\d+) commits? ahead, (\d+) commits? behind ([^ ]+)/, "領先 $1 個提交，落後 $2 個提交於 $3"],
        [/(\d+) commits? behind ([^ ]+)/, "落後 $1 個提交於 $2"],
        [/(\d+) commits? ahead ([^ ]+)/, "領先 $1 個提交於 $2"],
        [/Ahead behind count: (\d+)/, "領先落後數：$1"],
    ],
    "selector": [ // 元素篩選器規則
        ["a[data-target='branch-filter.allFilter']", "所有分支"],
