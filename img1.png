        [/(\d+) lines? \((\d+) loc\) ·/, "$1 行（$2 非空行）·"],  // loc = 程式碼行（line of code）= 行數 - 空行數（lines - blank lines）
        [/(\d+) References?/, "$1 次引用"],
        [/Blame prior to change ([a-f0-9]{7}), made on ([^ ]+)/, "追溯提交 $1，創建於 $2"],

        // 程式碼追溯頁面
        [/(\d+) contributors?/, "$1 位貢獻者"],
        [/(\d+) commits?/, "$1 個提交"],

        // 許可證
